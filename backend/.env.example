# Telegram Bot Token (required for Telegram WebApp auth)
TELEGRAM_BOT_TOKEN=123456:ABC-your_bot_token_here

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/vyud_db

# AI Provider Keys
# Groq API Key for Llama models
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API Key (if using Gemini models)
GEMINI_API_KEY=your_gemini_api_key_here
# or GOOGLE_API_KEY depending on library version
GOOGLE_API_KEY=your_google_api_key_here

# Optional: OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional: Anthropic Claude (premium quality)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# LiteLLM model override (default: groq/llama-3.3-70b-versatile)
# LITELLM_MODEL=claude-sonnet-4-6
